{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "version": 2,
  "buildCommand": "npm install && npm run build",
  "outputDirectory": "dist/pdi/browser",
  "rewrites": [
    {
      "source": "/(.*)",
      "destination": "/api/[[...route]]"
    }
  ],
  "env": {
    "NODE_ENV": "production"
  }
}
